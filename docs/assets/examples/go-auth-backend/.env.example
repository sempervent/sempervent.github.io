# Copy to .env and fill in values before running docker compose up

# Postgres
POSTGRES_DB=authdb
POSTGRES_USER=authuser
POSTGRES_PASSWORD=changeme_strong_password

# API
APP_PORT=8080
JWT_SECRET=changeme_at_least_32_chars_random
JWT_TTL_SECONDS=3600
BCRYPT_COST=12

# Optional
# CORS_ORIGINS=https://yourfrontend.example.com
