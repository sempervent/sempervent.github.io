{
  "theme": "default",
  "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
  "fontSize": 14,
  "flowchart": {
    "curve": "linear",
    "padding": 16,
    "nodeSpacing": 50,
    "rankSpacing": 60,
    "htmlLabels": true,
    "useMaxWidth": true
  },
  "themeVariables": {
    "primaryColor": "#e0f2f1",
    "primaryTextColor": "#1a1a1a",
    "primaryBorderColor": "#00897b",
    "lineColor": "#546e7a",
    "secondaryColor": "#f5f5f5",
    "tertiaryColor": "#fafafa"
  }
}
